{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PSModuleMaintenance Configuration",
  "description": "Configuration schema for PSModuleMaintenance script",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference"
    },
    "_comment": {
      "type": "string",
      "description": "Optional comment field"
    },
    "ExcludedModules": {
      "type": "array",
      "description": "List of module names to exclude from updates and pruning",
      "items": {
        "type": "string"
      },
      "default": [],
      "examples": [
        ["Az.Accounts", "Microsoft.Graph.Authentication"]
      ]
    },
    "LogRetentionDays": {
      "type": "integer",
      "description": "Number of days to retain log files before automatic cleanup",
      "minimum": 1,
      "maximum": 365,
      "default": 180
    },
    "TrustPSGallery": {
      "type": "boolean",
      "description": "Whether to trust PSGallery repository during updates",
      "default": true
    },
    "NotificationMode": {
      "type": "string",
      "description": "When to show Windows toast notifications: Always, OnFailure, or Never",
      "enum": ["Always", "OnFailure", "Never"],
      "default": "Always"
    }
  },
  "additionalProperties": false
}
